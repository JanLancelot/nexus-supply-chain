<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1.1-phase1-fields" author="nexus-supply-chain">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="suppliers" columnName="lead_time_days"/>
            </not>
        </preConditions>
        <addColumn tableName="suppliers">
            <column name="lead_time_days" type="int" defaultValueNumeric="3"/>
        </addColumn>
        <addColumn tableName="orders">
            <column name="expected_delivery_date" type="timestamp with time zone"/>
            <column name="actual_delivery_date" type="timestamp with time zone"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
